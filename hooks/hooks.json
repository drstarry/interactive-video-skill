{
  "description": "Guards engine files from modification during lesson generation",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/guard_engine.sh"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ]
  }
}
